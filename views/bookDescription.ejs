<%- include('partials/header', {
    pageTitle: pageTitle,
    user: user
}) %>

<main class="container py-5">

    <a href="/#books" class="back-link">
        <i class="bi bi-arrow-left me-1"></i>
        Back to Books
    </a>

    <section class="book-details-card mt-4">

        <div class="row g-0">

            <div class="col-md-4 book-details-cover-section">
                <img
                    src="<%= book.image
                        ? '/images/' + book.image
                        : '/images/default-book.jpg' %>"
                    class="book-details-cover"
                    alt="Cover of <%= book.title %>"
                    onerror="this.onerror=null; this.src='/images/default-book.jpg';"
                >
            </div>

            <div class="col-md-8">

                <div class="book-details-content">

                    <span class="category-label">
                        <%= book.categoryName %>
                    </span>

                    <h1 class="display-6 fw-bold mt-3 mb-2">
                        <%= book.title %>
                    </h1>

                    <p class="book-details-author">
                        by <%= book.author %>
                    </p>

                    <div class="book-information-grid">

                        <div class="information-box">
                            <span class="information-label">ISBN</span>
                            <strong><%= book.isbn %></strong>
                        </div>

                        <div class="information-box">
                            <span class="information-label">Total Copies</span>
                            <strong><%= book.quantity %></strong>
                        </div>

                        <div class="information-box">
                            <span class="information-label">Available</span>
                            <strong><%= book.availableQuantity %></strong>
                        </div>

                    </div>

                    <div class="description-section">
                        <h2 class="h5 fw-bold">About this book</h2>

                        <p class="mb-0">
                            <%= book.description || 'No description is available for this book.' %>
                        </p>
                    </div>

                    <div class="mt-4">

                        <% if (book.availableQuantity > 0) { %>

                            <% if (user) { %>
                                <!-- Connect this form to the team's final borrow route -->
                                <form action="/borrow/<%= book.bookId %>" method="POST">
                                    <button type="submit" class="btn btn-warning btn-lg">
                                        <i class="bi bi-bookmark-plus me-1"></i>
                                        Borrow This Book
                                    </button>
                                </form>
                            <% } else { %>
                                <a href="/login" class="btn btn-warning btn-lg">
                                    Login to Borrow
                                </a>
                            <% } %>

                        <% } else { %>

                            <button class="btn btn-secondary btn-lg" disabled>
                                Currently Unavailable
                            </button>

                        <% } %>

                    </div>

                </div>
            </div>

        </div>

    </section>

</main>

<%- include('partials/footer') %>
