<%- include('partials/header', {
    pageTitle: pageTitle,
    user: user
}) %>

<header class="hero-section">
    <div class="container">
        <div class="row align-items-center g-4">

            <div class="col-lg-7">
                <span class="hero-label">
                    Explore. Borrow. Learn.
                </span>

                <h1 class="display-4 fw-bold mt-3">
                    Find your next great read
                </h1>

                <p class="lead hero-text">
                    Browse the library collection and view each book's
                    availability before borrowing.
                </p>

                <form action="/books" method="GET" class="hero-search mt-4">
                    <div class="input-group input-group-lg">
                        <input
                            type="text"
                            name="search"
                            class="form-control"
                            style="flex:3;"
                            placeholder="Search by title or author"
                            aria-label="Search books"
                            value="<%= search %>"
                        >
                        <select
                            name="genre"
                            class="form-select"
                        >
                            <option
                                value="all"
                                <%= selectedGenre === 'all'
                                    ? 'selected'
                                    : '' %>
                            >
                                All Genres
                            </option>

                            <% categories.forEach(category => { %>

                                <option
                                    value="<%= category.categoryId %>"
                                    <%= String(selectedGenre) ===
                                        String(category.categoryId)
                                        ? 'selected'
                                        : '' %>
                                >
                                    <%= category.categoryName %>
                                </option>

                            <% }) %>
                        </select>

                        <button class="btn btn-warning" type="submit" style="min-width:130px;">
                            <i class="bi bi-search me-1"></i>
                            Search
                        </button>
                    </div>
                </form>
            </div>

            <div class="col-lg-5 text-center">
                <div class="hero-book-icon">
                    <i class="bi bi-journal-bookmark-fill"></i>
                </div>
            </div>

        </div>
    </div>
</header>

<main class="container py-5" id="books">

    <div class="section-heading">
        <div>
            <p class="section-eyebrow mb-1">OUR COLLECTION</p>
            <h2 class="fw-bold mb-0">Available Books</h2>
        </div>

        <span class="book-count">
            <%= books.length %> book<%= books.length === 1 ? '' : 's' %>
        </span>
    </div>

    <% if (books.length > 0) { %>

        <div class="row g-4 mt-2">

            <% books.forEach(book => { %>

                <div class="col-sm-6 col-lg-4">

                    <article class="card book-card h-100">

                        <div class="book-cover-wrapper">
                            <img
                                src="<%= book.image
                                    ? '/images/' + book.image
                                    : '/images/default-book.jpg' %>"
                                class="book-cover"
                                alt="Cover of <%= book.title %>"
                                onerror="this.onerror=null; this.src='/images/default-book.jpg';"
                            >

                            <% if (book.availableQuantity > 0) { %>
                                <span class="availability-badge available">
                                    Available
                                </span>
                            <% } else { %>
                                <span class="availability-badge unavailable">
                                    Unavailable
                                </span>
                            <% } %>
                        </div>

                        <div class="card-body d-flex flex-column">

                            <span class="category-label">
                                <%= book.categoryName %>
                            </span>

                            <h3 class="h5 card-title fw-bold mt-2">
                                <%= book.title %>
                            </h3>

                            <p class="book-author">
                                by <%= book.author %>
                            </p>

                            <p class="book-description">
                                <%= book.description || 'No description available.' %>
                            </p>

                            <div class="book-stock mt-auto mb-3">
                                <i class="bi bi-book me-1"></i>
                                <%= book.availableQuantity %> of
                                <%= book.quantity %> available
                            </div>

                            <a
                                href="/book/<%= book.bookId %>"
                                class="btn btn-primary w-100"
                            >
                                View Book Details
                            </a>

                        </div>
                    </article>

                </div>

            <% }) %>

        </div>

    <% } else { %>

        <section class="empty-state text-center">
            <i class="bi bi-journal-x empty-icon"></i>
            <h3 class="mt-3">No books found</h3>
            <p class="text-muted mb-0">
                Books added to the database will appear here.
            </p>
        </section>

    <% } %>

</main>

<%- include('partials/footer') %>
