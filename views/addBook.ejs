<%- include('partials/header', {
    pageTitle: 'Add Book',
    user: user
}) %>

<main class="container py-5">

    <a href="/#books" class="back-link">
        <i class="bi bi-arrow-left me-1"></i>
        Back to Books
    </a>

    <section class="book-details-card mt-4">
        <div class="book-details-content" style="padding: 40px;">

            <span class="section-eyebrow">LIBRARY MANAGEMENT</span>
            <h1 class="h3 fw-bold mt-2 mb-4">Add a New Book</h1>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <form action="/addBook" method="POST">

                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label" for="title">Title</label>
                        <input type="text" class="form-control" id="title" name="title" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="author">Author</label>
                        <input type="text" class="form-control" id="author" name="author" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="isbn">ISBN</label>
                        <input type="text" class="form-control" id="isbn" name="isbn" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="categoryId">Category</label>
                        <select class="form-select" id="categoryId" name="categoryId" required>
                            <option value="" disabled selected>Select a category</option>
                            <% categories.forEach(cat => { %>
                                <option value="<%= cat.categoryId %>">
                                    <%= cat.categoryName %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="quantity">Total Copies</label>
                        <input type="number" min="0" class="form-control" id="quantity" name="quantity" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="availableQuantity">Available Copies</label>
                        <input type="number" min="0" class="form-control" id="availableQuantity" name="availableQuantity" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="image">Cover Image</label>
                        <input type="file" class="form-control" id="image" name="image" accept="image/*">
                    </div>

                    <div class="col-12">
                        <label class="form-label" for="description">Description</label>
                        <textarea class="form-control" id="description" name="description" rows="4"></textarea>
                    </div>

                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-warning btn-lg">
                        <i class="bi bi-plus-circle me-1"></i>
                        Add Book
                    </button>
                </div>

            </form>

        </div>
    </section>

</main>

<%- include('partials/footer') %>
