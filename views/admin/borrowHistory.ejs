<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= pageTitle %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-4">
    <h2>All Borrow History</h2>
    <hr>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Member Name</th>
                <th>Book Title</th>
                <th>Author</th>
                <th>Borrow Date</th>
                <th>Due Date</th>
                <th>Return Date</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            <% records.forEach(r => { %>
            <tr>
                <td><%= r.name %></td>
                <td><%= r.title %></td>
                <td><%= r.author %></td>
                <td><%= r.borrowDate %></td>
                <td><%= r.returnDate || '-' %></td>
                <td><%= r.returnDate || '-' %></td>
                <td>
                    <% if(r.returnDate){ %>
                        <span class="text-success">Returned</span>
                    <% }else{ %>
                        <span class="text-danger">Borrowed</span>
                    <% } %>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>

    <div class="mt-4">
        <a href="/admin" class="btn btn-secondary">Back to Admin Dashboard</a>
    </div>
</body>
</html>