<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/header') %>
</head>

<body class="bg-light">

    <%- include('../partials/adminTabs') %>

    <div class="container py-4">

        <h2>All Borrow History</h2>
        <hr>

        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Member Name</th>
                    <th>Book Title</th>
                    <th>Author</th>
                    <th>Borrow Date</th>
                    <th>Due Date</th>
                    <th>Return Date</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                <% records.forEach(r => { %>
                <tr>
                    <td><%= r.name %></td>
                    <td><%= r.title %></td>
                    <td><%= r.author %></td>

                    <td>
                        <%= r.borrowDate 
                            ? new Date(r.borrowDate).toLocaleDateString('en-GB') 
                            : '-' %>
                    </td>

                    <td>
                        <%= r.dueDate 
                            ? new Date(r.dueDate).toLocaleDateString('en-GB') 
                            : '-' %>
                    </td>

                    <td>
                        <%= r.returnDate 
                            ? new Date(r.returnDate).toLocaleDateString('en-GB') 
                            : '-' %>
                    </td>

                    <td>
                        <% if (r.returnDate) { %>
                            <span class="text-success">Returned</span>
                        <% } else { %>
                            <span class="text-danger">Borrowed</span>
                        <% } %>
                    </td>

                </tr>
                <% }) %>
            </tbody>
        </table>

        <div class="mt-4">
            <a href="/admin" class="btn btn-secondary">
                Back to Admin Dashboard
            </a>
        </div>

    </div>

    <%- include('../partials/footer') %>

</body>
</html>