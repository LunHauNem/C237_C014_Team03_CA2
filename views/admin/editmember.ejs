<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
</head>

<body class="bg-light">

<%- include('../partials/header') %>

<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow-sm border-0">

                <div class="card-body p-4">

                    <h3 class="mb-4">
                        <i class="bi bi-pencil-square"></i>
                        Edit Member
                    </h3>

                    <form action="/admin/members/edit/<%= member.userId %>" method="POST">

                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input
                                type="text"
                                name="name"
                                class="form-control"
                                value="<%= member.name %>"
                                required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input
                                type="email"
                                name="email"
                                class="form-control"
                                value="<%= member.email %>"
                                required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Role</label>

                            <select
                                name="role"
                                class="form-select">

                                <option value="member"
                                    <%= member.role === 'member' ? 'selected' : '' %>>
                                    Member
                                </option>

                                <option value="admin"
                                    <%= member.role === 'admin' ? 'selected' : '' %>>
                                    Admin
                                </option>

                            </select>

                        </div>

                        <button class="btn btn-success">
                            Save Changes
                        </button>

                        <a href="/admin/members"
                           class="btn btn-secondary">
                            Cancel
                        </a>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

<%- include('../partials/footer') %>

</body>
</html>