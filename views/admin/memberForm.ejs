<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
</head>
<body class="bg-light">
  <%- include('../partials/header') %>

  <div class="container py-4">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card shadow-sm border-0">
          <div class="card-body p-4">
            <h4 class="mb-4">
              <i class="bi bi-person-<%= formMode === 'add' ? 'plus' : 'gear' %>"></i>
              <%= formMode === 'add' ? 'Add New Member' : 'Edit Member' %>
            </h4>

            <form action="<%= formMode === 'add' ? '/admin/members/add' : '/admin/members/edit/' + member.userId + '?_method=PUT' %>" method="POST">
              <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input type="text" name="name" class="form-control" value="<%= member ? member.name : '' %>" required>
              </div>

              <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" value="<%= member ? member.email : '' %>" required>
              </div>

              <% if (formMode === 'add') { %>
                <div class="mb-3">
                  <label class="form-label">Password</label>
                  <input type="password" name="password" class="form-control" minlength="6" required>
                </div>
              <% } else { %>
                <div class="alert alert-light border small">
                  Passwords can only be changed by the member themselves, from their own Profile page.
                </div>
              <% } %>

              <div class="mb-3">
                <label class="form-label">Role</label>
                <select name="role" class="form-select" required>
                  <option value="member" <%= member && member.role === 'member' ? 'selected' : '' %>>Member</option>
                  <option value="admin" <%= member && member.role === 'admin' ? 'selected' : '' %>>Admin</option>
                </select>
              </div>

              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">
                  <i class="bi bi-check-lg"></i> <%= formMode === 'add' ? 'Add Member' : 'Save Changes' %>
                </button>
                <a href="/admin/members" class="btn btn-outline-secondary">Cancel</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
