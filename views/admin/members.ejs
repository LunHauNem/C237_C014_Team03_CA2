<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/header') %>
</head>
<body class="bg-light">
<%- include('../partials/adminTabs') %>

  <div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
      <h2 class="mb-0"><i class="bi bi-people"></i> Member List</h2>
      <a href="/admin/members/add" class="btn btn-success">
        <i class="bi bi-person-plus"></i> Add New Member
      </a>
    </div>

    <form action="/admin/members" method="GET" class="mb-3">
      <div class="input-group">
        <input type="text" name="search" value="<%= search %>" class="form-control"
               placeholder="Search by name or email...">
        <button class="btn btn-outline-dark" type="submit"><i class="bi bi-search"></i> Search</button>
        <% if (search) { %>
          <a href="/admin/members
    </form>

    <div class="card shadow-sm border-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-dark">
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Joined</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (members.length === 0) { %>
              <tr><td colspan="6" class="text-center text-muted py-4">No members found.</td></tr>
            <% } %>
            <% members.forEach(m => { %>
              <tr>
                <td><%= m.userId %></td>
                <td><%= m.name %></td>
                <td><%= m.email %></td>
                <td>
                  <span class="badge bg-<%= m.role === 'admin' ? 'dark' : 'primary' %>"><%= m.role %></span>
                </td>
                <td><%= new Date(m.createdAt).toLocaleDateString() %></td>
                <td class="text-end">
                  <a href="/admin/members/edit/<%= m.userId %>" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil"></i> Edit
                  </a>
                  <% if (m.userId !== user.userId) { %>
                    <form action="/admin/members/delete/<%= m.userId %>?_method=DELETE" method="POST" class="d-inline"
                          onsubmit="return confirm('Delete \'<%= m.name %>\'? This cannot be undone.');">
                      <button type="submit" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-trash"></i> Delete
                      </button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
